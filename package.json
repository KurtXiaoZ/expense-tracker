{
  "name": "expense-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "postinstall": "prisma generate",
    "reset": "rm -rf node_modules .next build out && npm install",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
